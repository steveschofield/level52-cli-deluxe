EVIDENCE: `"version":"2.2.4","component":"jquery","npmname":"jquery","detection":"filecontent","vulnerabilities":[{"info":["..."],"below":"3.0.0-beta1","atOrAbove":"1.12.3","severity":"medium","identifiers":{"summary":"3rd party CORS request may execute","issue":"2432","CVE":["CVE-2015-9251"],"githubID":"GHSA-rmxg-73gg-4p98"}},"cwe":["CWE-79"]}`
